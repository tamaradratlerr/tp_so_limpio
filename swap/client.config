# Configuración del SWAP
# Este archivo define cómo se crea el archivo de disco
SWAP_FILE_PATH=/tmp/tp_so_swapfile.bin
SWAP_FILE_SIZE=2048
BLOCK_SIZE=64

# Datos de red para que el SWAP sepa dónde escuchar
# Y opcionalmente la IP/PUERTO del KM si el SWAP necesita validarlo
IP_KM=127.0.0.1
PUERTO_KM=8002
